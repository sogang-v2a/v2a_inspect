{
  "artifacts": [
    {
      "name": "sam3",
      "repository": "facebook/sam3",
      "revision": "main",
      "relative_path": "sam3",
      "allow_patterns": [
        "*.json",
        "*.safetensors",
        "*.bin",
        "*.txt",
        "*.model",
        "*.py",
        "README*"
      ]
    },
    {
      "name": "embedding",
      "repository": "facebook/dinov2-base",
      "revision": "main",
      "relative_path": "embeddings/dinov2",
      "allow_patterns": [
        "*.json",
        "*.safetensors",
        "*.bin",
        "*.txt",
        "preprocessor_config.json",
        "README*"
      ]
    },
    {
      "name": "label",
      "repository": "google/siglip2-base-patch16-224",
      "revision": "main",
      "relative_path": "labels/siglip2",
      "allow_patterns": [
        "*.json",
        "*.safetensors",
        "*.bin",
        "*.txt",
        "*.model",
        "tokenizer*",
        "spiece*",
        "README*"
      ]
    }
  ]
}
